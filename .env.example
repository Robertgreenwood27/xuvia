# ──────────────────────────────────────────────────────
# XUVIA — Environment Variables
# Copy this to .env.local and fill in your values.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────

# Printful API key (from Printful Dashboard → Settings → API Access)
# When set, the /api/products route will fetch live store products.
# Leave blank to use the local product catalog in lib/products.js
PRINTFUL_API_KEY=

# Stripe (for future direct checkout — not needed if using Printful's hosted checkout)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Site URL (used for OG tags and canonical links)
NEXT_PUBLIC_SITE_URL=https://xuvia.com
